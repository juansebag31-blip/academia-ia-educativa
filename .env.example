# Public Supabase configuration. These values are safe to expose in the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Canonical application URL. Vercel will provide the initial *.vercel.app URL.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Server-only key reserved for administrative migration and maintenance scripts.
# Never prefix this value with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# Server-only marketing configuration. Use long, independent random values.
MARKETING_HASH_SECRET=
MARKETING_DOWNLOAD_SECRET=

# Optional email delivery. Downloads still work when Resend is not configured.
RESEND_API_KEY=
RESEND_FROM_EMAIL=Academia IA <recursos@example.com>

# Public contact shown in the privacy page.
NEXT_PUBLIC_CONTACT_EMAIL=
